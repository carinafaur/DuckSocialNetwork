<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox prefHeight="600.0" prefWidth="550.0" spacing="0.0"
      style="-fx-background-color: white;"
      xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="controller.FriendsController">

    <children>
        <HBox alignment="CENTER_LEFT" prefHeight="80.0" spacing="20.0"
              style="-fx-background-color: #f8f9fa; -fx-border-color: #dfe6e9; -fx-border-width: 0 0 1 0;">
            <children>
                <VBox alignment="CENTER_LEFT" HBox.hgrow="ALWAYS">
                    <children>
                        <Label text="Community" style="-fx-text-fill: #2d3436; -fx-font-weight: bold;">
                            <font>
                                <Font size="24.0" />
                            </font>
                        </Label>
                        <Label text="Manage your duck connections" style="-fx-text-fill: #636e72; -fx-font-size: 13;" />
                    </children>
                </VBox>
                <Button mnemonicParsing="false" onAction="#handleRefreshFriends"
                        style="-fx-background-color: #0984e3; -fx-text-fill: white; -fx-background-radius: 20; -fx-font-weight: bold; -fx-cursor: hand;"
                        text="🔄 Refresh" prefHeight="35.0">
                    <padding>
                        <Insets left="15.0" right="15.0" />
                    </padding>
                </Button>
            </children>
            <padding>
                <Insets left="30.0" right="30.0" />
            </padding>
        </HBox>

        <VBox VBox.vgrow="ALWAYS">
            <padding>
                <Insets bottom="20.0" left="20.0" right="20.0" top="10.0" />
            </padding>
            <children>
                <TableView fx:id="friendsTableView" VBox.vgrow="ALWAYS"
                           style="-fx-background-color: white; -fx-background-insets: 0; -fx-border-color: #dfe6e9; -fx-border-radius: 10; -fx-background-radius: 10;">
                    <columns>
                        <TableColumn fx:id="usernameColumn" prefWidth="250.0" text="Username"
                                     style="-fx-font-size: 14px; -fx-alignment: CENTER_LEFT;" />
                        <TableColumn fx:id="actionColumn" prefWidth="240.0" text="Status"
                                     style="-fx-alignment: CENTER;" />
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                    </columnResizePolicy>
                </TableView>
            </children>
        </VBox>
    </children>
</VBox>