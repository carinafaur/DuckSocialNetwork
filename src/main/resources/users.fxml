<?xml version="1.0" encoding="UTF-8"?>

        <?import javafx.geometry.Insets?>
        <?import javafx.scene.control.*?>
        <?import javafx.scene.layout.*?>

<TabPane prefHeight="600.0" prefWidth="800.0" tabClosingPolicy="UNAVAILABLE" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.UserController">
    <tabs>

        <Tab text="Ducks">
            <content>
                <VBox spacing="15.0" style="-fx-background-color: white; -fx-background-radius: 10;">
                    <padding>
                        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
                    </padding>
                    <children>
                        <HBox alignment="CENTER_LEFT" spacing="10.0" style="-fx-background-color: #f8f9fa; -fx-padding: 15; -fx-background-radius: 10;">
                            <children>
                                <ComboBox fx:id="userComboBox" prefWidth="200.0" promptText="Filter Ducks" onAction="#userComboBoxAction" style="-fx-background-radius: 20; -fx-background-color: white; -fx-border-color: #dfe6e9; -fx-border-radius: 20;" />
                                <Button fx:id="addDuckButton" onAction="#addDuckScene"
                                        style="-fx-background-color: #0984e3; -fx-text-fill: white; -fx-background-radius: 20; -fx-font-weight: bold;" text="＋ Add Duck" />
                                <Button fx:id="deleteDuckButton" onAction="#deleteDuck"
                                        style="-fx-background-color: #ff7675; -fx-text-fill: white; -fx-background-radius: 20; -fx-font-weight: bold;" text="🗑 Delete" />
                                <Button fx:id="refreshDucksButton" style="-fx-background-color: #b2bec3; -fx-text-fill: white; -fx-background-radius: 20;" text="🔄" />    </children>
                        </HBox>

                        <TableView fx:id="duckTableView" VBox.vgrow="ALWAYS" style="-fx-background-radius: 10; -fx-border-radius: 10; -fx-border-color: #dfe6e9; -fx-background-insets: 0;">
                            <columns>
                                <TableColumn fx:id="duckIdColumn" prefWidth="50.0" text="ID" />
                                <TableColumn fx:id="duckUsernameColumn" prefWidth="150.0" text="Username" />
                                <TableColumn fx:id="duckEmailColumn" prefWidth="150.0" text="Email" />
                                <TableColumn fx:id="duckPasswordColumn" prefWidth="150.0" text="Password" />
                                <TableColumn fx:id="duckTypeColumn" prefWidth="100.0" text="Type" />
                                <TableColumn fx:id="duckSpeedColumn" text="Speed" />
                                <TableColumn fx:id="duckResistanceColumn" text="Resistance" />
                            </columns>
                        </TableView>

                        <HBox alignment="CENTER" spacing="50.0">
                            <Button fx:id="previousDuckButton" text="&lt;&lt; Previous" style="-fx-background-color: white; -fx-border-color: #0984e3; -fx-text-fill: #0984e3; -fx-background-radius: 20;" onAction="#previousDuckAction"/>
                            <Button fx:id="nextDuckButton" text="Next &gt;&gt;" style="-fx-background-color: white; -fx-border-color: #0984e3; -fx-text-fill: #0984e3; -fx-background-radius: 20;" onAction="#nextDuckAction"/>
                        </HBox>
                    </children>
                </VBox>
            </content>
        </Tab>

        <Tab text="Persons">
            <content>
                <VBox spacing="15.0" style="-fx-background-color: white; -fx-background-radius: 10;">
                    <padding>
                        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
                    </padding>
                    <children>
                        <HBox alignment="CENTER_LEFT" spacing="10.0">
                            <children>
                                <Button fx:id="addPersonButton" onAction="#addPersonScene"
                                        style="-fx-background-color: #00b894; -fx-text-fill: white; -fx-background-radius: 20; -fx-font-weight: bold; -fx-cursor: hand;"
                                        text="＋ Add Person" />
                                <Button fx:id="deletePersonButton" onAction="#deletePerson"
                                        style="-fx-background-color: #ff7675; -fx-text-fill: white; -fx-background-radius: 20; -fx-font-weight: bold; -fx-cursor: hand;"
                                        text="🗑 Delete Person" />
                            </children>
                        </HBox>

                        <TableView fx:id="personTableView" VBox.vgrow="ALWAYS" style="-fx-background-radius: 10; -fx-border-radius: 10; -fx-border-color: #dfe6e9; -fx-background-insets: 0;">
                            <columns>
                                <TableColumn fx:id="personIdColumn" prefWidth="50.0" text="ID" />
                                <TableColumn fx:id="personUsernameColumn" prefWidth="120.0" text="Username" />
                                <TableColumn fx:id="personEmailColumn" prefWidth="120.0" text="Email" />
                                <TableColumn fx:id="personPasswordColumn" prefWidth="120.0" text="Password" />
                                <TableColumn fx:id="personFNameColumn" prefWidth="120.0" text="First Name" />
                                <TableColumn fx:id="personLNameColumn" prefWidth="120.0" text="Last Name" />
                                <TableColumn fx:id="personDateColumn" prefWidth="120.0" text="Date of Birth" />
                                <TableColumn fx:id="personOcupationColumn" prefWidth="120.0" text="Occupation" />
                                <TableColumn fx:id="personEmpathyLevelColumn" prefWidth="120.0" text="Empathy Level" />
                            </columns>
                        </TableView>

                        <HBox alignment="CENTER" spacing="50.0">
                            <children>
                                <Button fx:id="previousPersonButton" text="&lt;&lt; Previous" style="-fx-background-color: white; -fx-border-color: #0984e3; -fx-text-fill: #0984e3; -fx-background-radius: 20;" onAction="#previousPersonAction" />
                                <Button fx:id="nextPersonButton" text="Next &gt;&gt;" style="-fx-background-color: white; -fx-border-color: #0984e3; -fx-text-fill: #0984e3; -fx-background-radius: 20;" onAction="#nextPersonAction" />
                            </children>
                        </HBox>
                    </children>
                </VBox>
            </content>
        </Tab>

        <Tab text="Friendships">
            <content>
                <VBox spacing="15.0" style="-fx-background-color: white;">
                    <padding>
                        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
                    </padding>
                    <children>
                        <HBox alignment="CENTER_LEFT" spacing="10.0">
                            <children>
                                <Button fx:id="addFriendshipButton" onAction="#addFriendshipScene"
                                        style="-fx-background-color: #00b894; -fx-text-fill: white; -fx-background-radius: 20; -fx-font-weight: bold;" text="＋ Add Friendship" />
                                <Button fx:id="deleteFriendshipButton" onAction="#deleteFriendship"
                                        style="-fx-background-color: #fab1a0; -fx-text-fill: #e17055; -fx-background-radius: 20;" text="Delete" />
                                <Separator orientation="VERTICAL" />
                                <Button fx:id="nrCommunitiesButton" onAction="#showNumberCommunities"
                                        style="-fx-background-color: #a29bfe; -fx-text-fill: white; -fx-background-radius: 20;" text="📊 Number of communities" />
                                <Button fx:id="sociableCommunityButton" onAction="#showMostSociable"
                                        style="-fx-background-color: #fdcb6e; -fx-text-fill: white; -fx-background-radius: 20;" text="🏆 Most Sociable" />  </children>
                        </HBox>

                        <TableView fx:id="friendshipTableView" VBox.vgrow="ALWAYS" style="-fx-background-radius: 10;">
                            <columns>
                                <TableColumn fx:id="friendshipId1Column" prefWidth="150.0" text="User 1 ID" />
                                <TableColumn fx:id="friendshipId2Column" prefWidth="150.0" text="User 2 ID" />
                                <TableColumn fx:id="friendshipTypeColumn" prefWidth="150.0" text="Friendship Type" />
                            </columns>
                        </TableView>

                        <HBox alignment="CENTER" spacing="50.0">
                            <children>
                                <Button fx:id="previousFriendshipButton" text="&lt;&lt; Previous" style="-fx-background-color: white; -fx-border-color: #0984e3; -fx-text-fill: #0984e3; -fx-background-radius: 20;" onAction="#previousFriendshipAction" />
                                <Button fx:id="nextFriendshipButton" text="Next &gt;&gt;" style="-fx-background-color: white; -fx-border-color: #0984e3; -fx-text-fill: #0984e3; -fx-background-radius: 20;" onAction="#nextFriendshipAction" />
                            </children>
                        </HBox>
                    </children>
                </VBox>
            </content>
        </Tab>

    </tabs>
</TabPane>