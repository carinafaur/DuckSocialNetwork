<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.shape.Circle?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.Tab?>
<VBox spacing="20" prefWidth="600" style="-fx-background-color: white;" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.UserProfileController">
    <children>
        <HBox spacing="40" alignment="CENTER_LEFT">
            <padding><Insets top="20" left="50" bottom="20"/></padding>
            <children>
                <Circle fx:id="profileCircle" radius="50" fill="#dfe6e9" stroke="#b2bec3" />

                <VBox spacing="10">
                    <HBox spacing="20" alignment="CENTER_LEFT">
                        <Label fx:id="usernameLabel" text="username" style="-fx-font-size: 20; -fx-font-weight: bold;"/>
                    </HBox>

                    <HBox spacing="30">
                         <Label fx:id="friendsCountLabel" text="0 friends" style="-fx-font-weight: bold;"/>
                        <Label fx:id="likeCountLabel" text="0 likes" style="-fx-font-weight: bold;"/>
                    </HBox>

                    <Label fx:id="descriptionLabel" style="-fx-font-weight: bold;"/>
                    <Label fx:id="statusLabel" style="-fx-font-weight: bold;"/>
                </VBox>
            </children>
        </HBox>

        <Separator />

        <TabPane tabClosingPolicy="UNAVAILABLE">
            <tabs>
                <Tab text="FRIENDS">
                    <ListView fx:id="friendsListView" />
                </Tab>
                <Tab text="EVENTS">
                    <ListView fx:id="eventsListView" />
                </Tab>
            </tabs>
        </TabPane>
    </children>
</VBox>