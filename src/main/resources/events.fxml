<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER" spacing="15.0" prefHeight="450.0" prefWidth="500.0"
      xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="controller.EventController">

    <children>
        <Label text="Race Events Management">
            <font>
                <Font name="System Bold" size="20.0" />
            </font>
        </Label>

        <ListView fx:id="eventsListView" VBox.vgrow="ALWAYS" />

        <HBox alignment="CENTER" spacing="50.0">
            <children>
                <Button fx:id="previousEventButton" text="&lt;&lt; Previous" style="-fx-background-color: white; -fx-border-color: #0984e3; -fx-text-fill: #0984e3; -fx-background-radius: 20;" onAction="#previousEventAction" />
                <Button fx:id="nextEventButton" text="Next &gt;&gt;" style="-fx-background-color: white; -fx-border-color: #0984e3; -fx-text-fill: #0984e3; -fx-background-radius: 20;" onAction="#nextEventAction" />
            </children>
        </HBox>

        <HBox alignment="CENTER" spacing="20.0">
            <children>
                <Button fx:id="btnSubscribe" mnemonicParsing="false"
                        onAction="#subscribeUser" prefHeight="35.0" prefWidth="120.0"
                        text="Subscribe" style="-fx-background-color: #4CAF50; -fx-text-fill: white;">
                    <font>
                        <Font name="System Bold" size="13.0" />
                    </font>
                </Button>

                <Button fx:id="btnUnsubscribe" mnemonicParsing="false"
                        onAction="#unsubscribeUser" prefHeight="35.0" prefWidth="120.0"
                        text="Unsubscribe" style="-fx-background-color: #4CAF50; -fx-text-fill: white;">
                    <font>
                        <Font name="System Bold" size="13.0" />
                    </font>
                </Button>

                <Button fx:id="addEventButton" onAction="#addEventScene" prefHeight="35.0"
                        style="-fx-background-color: #74b9ff; -fx-text-fill: #0984e3; -fx-background-radius: 20; -fx-font-weight: bold;"
                        text="🏁 Add Event" />

                <Button fx:id="btnFinish" mnemonicParsing="false"
                        onAction="#finishEvent" prefHeight="35.0" prefWidth="120.0"
                        text="Finish Event" style="-fx-background-color: #f44336; -fx-text-fill: white;">
                    <font>
                        <Font name="System Bold" size="13.0" />
                    </font>
                </Button>
            </children>
            <padding>
                <Insets bottom="10.0" top="10.0" />
            </padding>
        </HBox>
    </children>

    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>
</VBox>