<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER" spacing="20.0" prefWidth="400.0" style="-fx-background-color: #f4f7f6;"
      xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="controller.AddEventController">
    <children>
        <Label text="🏆 Create New Race Event">
            <font>
                <Font name="System Bold" size="18.0" />
            </font>
        </Label>

        <GridPane hgap="10.0" vgap="15.0">
            <columnConstraints>
                <ColumnConstraints halignment="RIGHT" hgrow="SOMETIMES" minWidth="10.0" prefWidth="120.0" />
                <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="200.0" />
            </columnConstraints>
            <rowConstraints>
                <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
            </rowConstraints>
            <children>
                <Label text="Event Name:" />
                <TextField fx:id="eventNameField" promptText="e.g. Grand Prix" GridPane.columnIndex="1" />

                <Label text="Distances (comma sep):" GridPane.rowIndex="1" />
                <TextField fx:id="distancesField" promptText="e.g. 100, 200, 500" GridPane.rowIndex="1" GridPane.columnIndex="1" />

            </children>
        </GridPane>

        <HBox alignment="CENTER" spacing="15.0">
            <children>
                <Button mnemonicParsing="false" onAction="#addEventAction" prefWidth="130.0"
                        style="-fx-background-color: #0984e3; -fx-text-fill: white; -fx-font-weight: bold;" text="Create Event" />
            </children>
        </HBox>
    </children>
    <padding>
        <Insets bottom="25.0" left="30.0" right="30.0" top="25.0" />
    </padding>
</VBox>